{
  "expo": {
    "name": "InspirArt",
    "slug": "InspirArt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-inspirart.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-isp.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-inspirart.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/flavicon-inspirart.png"
    }
  }
}